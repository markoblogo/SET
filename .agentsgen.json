{
  "version": 1,
  "mode": "safe",
  "on_missing_markers": "error",
  "generated_suffix": ".generated",
  "markers": {
    "start": "<!-- AGENTSGEN:START section={section} -->",
    "end": "<!-- AGENTSGEN:END section={section} -->"
  },
  "sections": [
    "agentsgen_contract",
    "task_contract",
    "verification"
  ],
  "pack": {
    "enabled": true,
    "llms_format": "txt",
    "output_dir": "docs/ai",
    "files": [
      "docs/ai/task-contract.json"
    ]
  },
  "commands": {
    "lint": "python3 -m json.tool .agentsgen.json >/dev/null"
  }
}
